{
  "name": "llm-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "CLOUDFLARE_ENV=staging npm run build && wrangler deploy",
    "deploy:production": "CLOUDFLARE_ENV=production npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "react-router typegen && tsc -b",
    "reset:db": "lsof -i :8421 -t 2>/dev/null | xargs -r kill -9 2>/dev/null; rm -rf .wrangler && echo '✓ Local DO storage + R2 simulator wiped. Run npm run dev to restart.'"
  },
  "dependencies": {
    "@cloudflare/codemode": "^0.3.4",
    "@cloudflare/shell": "^0.3.6",
    "@cloudflare/think": "^0.5.0",
    "@twa-dev/sdk": "^8.0.2",
    "agents": "^0.12.0",
    "ai": "^6.0.172",
    "cytoscape": "^3.33.3",
    "hono": "^4.11.9",
    "marked": "^18.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.0",
    "workers-ai-provider": "^3.1.13",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.25.0",
    "@react-router/dev": "7.13.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/cytoscape": "^3.21.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "4.1.18",
    "typescript": "^5.5.0",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "6.1.1",
    "wrangler": "^4.87.0"
  }
}
