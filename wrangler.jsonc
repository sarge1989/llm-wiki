{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bw-task-tracker-bot",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "dev": {
    "port": 8421,
  },
  "ai": {
    "binding": "AI",
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyAgent",
        "name": "MyAgent",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": ["MyAgent"],
      "tag": "v1",
    },
  ],
  "r2_buckets": [
    {
      "bucket_name": "bw-task-tracker-bot-workspace",
      "binding": "llm_wiki_workspace",
    },
  ],
  "browser": {
    "binding": "BROWSER",
  },
  "worker_loaders": [
    {
      "binding": "LOADER",
    },
  ],
  "queues": {
    "producers": [
      {
        "queue": "bw-task-tracker-bot-tasks",
        "binding": "TASK_QUEUE",
      },
    ],
    "consumers": [
      {
        "queue": "bw-task-tracker-bot-tasks",
        "max_batch_size": 1,
        "max_batch_timeout": 1,
        "max_retries": 0,
      },
    ],
  },
  "env": {
    "production": {
      "name": "bw-task-tracker-bot",
      "vars": {
        "ENVIRONMENT": "production",
      },
      "ai": {
        "binding": "AI",
      },
      "durable_objects": {
        "bindings": [
          {
            "class_name": "MyAgent",
            "name": "MyAgent",
          },
        ],
      },
      "migrations": [
        {
          "new_sqlite_classes": ["MyAgent"],
          "tag": "v1",
        },
      ],
      "r2_buckets": [
        {
          "bucket_name": "bw-task-tracker-bot-workspace",
          "binding": "llm_wiki_workspace",
        },
      ],
      "browser": {
        "binding": "BROWSER",
      },
      "worker_loaders": [
        {
          "binding": "LOADER",
        },
      ],
      "queues": {
        "producers": [
          {
            "queue": "bw-task-tracker-bot-tasks",
            "binding": "TASK_QUEUE",
          },
        ],
        "consumers": [
          {
            "queue": "bw-task-tracker-bot-tasks",
            "max_batch_size": 1,
            "max_batch_timeout": 1,
            "max_retries": 0,
          },
        ],
      },
    },
  },
}
