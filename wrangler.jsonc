{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "llm-wiki",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "dev": { "port": 8421 },
  "ai": {
    "binding": "AI",
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyAgent",
        "name": "MyAgent",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": ["MyAgent"],
      "tag": "v1",
    },
  ],
}
